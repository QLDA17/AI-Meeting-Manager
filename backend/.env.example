# ======================================
# MultiMinutes AI - Environment Configuration
# Copy this file to .env and fill in actual values
# ======================================

# ----------------------
# Environment
# ----------------------
ENVIRONMENT=development
DEBUG=true
TESTING=false
SECRET_KEY=your-secret-key-change-this-in-production-at-least-32-chars

# ----------------------
# Server Configuration
# ----------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true
WORKERS=1
CORS_ORIGINS=*
CORS_CREDENTIALS=true
REQUEST_TIMEOUT=300
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# ----------------------
# Database Configuration
# ----------------------
# Supported: mysql+pymysql:// or sqlite:///
DATABASE_URL=mysql+pymysql://multiminutes:multiminutes_password@localhost:3306/multiminutes

# Connection Pool (MySQL only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# SSL (MySQL production only)
DB_USE_SSL=false
DB_SSL_CA=/path/to/ca-cert.pem

# ----------------------
# AI/ML Provider Configuration
# ----------------------
# Choose provider: google, openai, anthropic, router
LLM_PROVIDER=router

# API Keys
GOOGLE_API_KEY=your_google_ai_studio_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Groq API for meeting summaries (free tier available)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
ROUTER_API_BASE_URL=https://api.groq.com/openai/v1
ROUTER_API_URL=
ROUTER_API_KEY=
ROUTER_MODEL=llama-3.3-70b-versatile
ROUTER_TIMEOUT_SECONDS=60

# Model settings
GEMINI_MODEL=gemini-1.5-flash
WHISPER_MODEL=base
PHOBERT_ENABLED=true
PHOBERT_LOAD_MODEL=true
PHOBERT_MODEL=vinai/phobert-base-v2
PHOBERT_DEVICE=auto
PHOBERT_DIALECT_ENABLED=true
PHOBERT_MLM_CORRECTION_ENABLED=false
PHOBERT_MAX_LENGTH=256
BARTPHO_ENABLED=true
BARTPHO_LOAD_MODEL=true
BARTPHO_MODEL=vinai/bartpho-word-base
BARTPHO_DEVICE=auto
BARTPHO_MAX_LENGTH=256
HF_HUB_OFFLINE=true
TRANSFORMERS_OFFLINE=true
AI_TEMPERATURE=0.2
AI_MAX_RETRIES=3

# ----------------------
# Cost Tracking
# ----------------------
COST_MONTHLY_LIMIT=10.0
COST_DAILY_LIMIT=1.0
COST_ALERT_THRESHOLD=0.8
COST_TRACKING_ENABLED=true

# ----------------------
# Logging & Monitoring
# ----------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
DB_ECHO=false

# ----------------------
# Rate Limiting
# ----------------------
RATE_LIMIT_RPM=100
RATE_LIMIT_WINDOW=60

# ----------------------
# External Services (Optional)
# ----------------------
# SMTP for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Redis (for caching, future use)
REDIS_URL=redis://localhost:6379/0

# ======================================
# Notes:
# - DATABASE_URL format: mysql+pymysql://user:password@host:port/database
# - For SQLite fallback: sqlite:///./multiminutes.db
# - SECRET_KEY should be at least 32 chars in production
# - LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ======================================
